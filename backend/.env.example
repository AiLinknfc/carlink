# CarLink Backend — FastAPI
#
# Variables de entorno requeridas:
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Base de datos (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Redis (Upstash compatible — redis[s]://user:password@host:port)
REDIS_URL=

# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=carlink-images
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# CORS
CORS_ORIGINS=http://localhost:3000,https://carlink.vercel.app

# JWT (Supabase public key — auto-fetched by default)
SUPABASE_JWT_SECRET=

# DeepSeek (structures raw OCR text from scanned receipts into title/vendor/date/cost)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tesseract (local OCR binary — reads text out of scanned images/PDFs before DeepSeek
# structures it. Requires the tesseract-ocr + tesseract-ocr-spa system packages; already
# installed in the Docker image. Leave blank to use the binary on PATH.)
TESSERACT_CMD=

# Server
PORT=8000
ENVIRONMENT=development
